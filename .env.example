# Browser-facing application APIs used during local development.
NEXT_PUBLIC_TETRIS_API_URL=http://localhost:8000
NEXT_PUBLIC_NEON_SHATTER_API_URL=http://localhost:8001
NEXT_PUBLIC_TWIN_API_URL=http://localhost:8002

# Optional: enables Google sign-in inside both Arcade games.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# scripts/deploy.sh requires equivalent production values through
# ARCADE_API_URL, TWIN_API_URL, and GOOGLE_CLIENT_ID shell variables.
